{
  "name": "english-phrase",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "concurrently --kill-others -n DB,API,WEB -c green,cyan,magenta \"pnpm db:studio\" \"pnpm api:dev\" \"pnpm web:dev\"",
    "release": "concurrently -n API,WEB -c cyan,magenta \"pnpm api:deploy\" \"pnpm web:deploy\"",
    "sync": "pnpm --filter sync run sync",
    "sync:local": "LOCAL=true pnpm --filter sync run sync",
    "test": "pnpm --filter sync run test",
    "db:generate": "pnpm --filter @english-phrase/db run generate",
    "db:studio": "pnpm --filter @english-phrase/db run studio",
    "db:migrate": "node --env-file=.env -e \"require('child_process').execSync('wrangler d1 execute ' + process.env.D1_DB_NAME + ' --remote --file=packages/db/migrations/0000_fluffy_impossible_man.sql', {stdio:'inherit'})\"",
    "db:migrate:local": "wrangler d1 execute english-phrase-db --local --file=packages/db/migrations/0000_fluffy_impossible_man.sql",
    "api:dev": "pnpm --filter api run dev",
    "api:deploy": "pnpm --filter api run deploy",
    "web:dev": "pnpm --filter web run dev",
    "web:build": "pnpm --filter web run build",
    "web:deploy": "pnpm --filter web run deploy",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "concurrently": "^9.2.1",
    "wrangler": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
